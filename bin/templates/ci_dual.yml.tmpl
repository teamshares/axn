name: CI

on:
  push:
    branches:
      - main
  pull_request:

jobs:
  ci:
    # Reusable workflow in axn core — fix CI once there, every gem inherits it.
    uses: teamshares/axn/.github/workflows/gem-ci.yml@main
    with:
      # Dual topology: the default rake is Rails-free; run the dummy-app suite in a separate job.
      rails-specs-job: true
