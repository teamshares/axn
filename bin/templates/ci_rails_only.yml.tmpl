name: CI

on:
  push:
    branches:
      - main
  pull_request:

jobs:
  ci:
    # Reusable workflow in axn core — fix CI once there, every gem inherits it.
    uses: teamshares/axn/.github/workflows/gem-ci.yml@main
    with:
      # Rails-only: the default rake runs the dummy-app suite, so the main job needs its bundle.
      main-needs-dummy-app: true
