# frozen_string_literal: true

source "https://rubygems.org"

# Use the local axn gem for testing
gem "axn", path: "../../"

# Rails dependencies
gem "rails", "~> 7.0"

# Use sqlite3 as the database for Active Record
gem "sqlite3", "~> 2.0"

# Use the Puma web server [https://github.com/puma/puma]
gem "puma", "~> 7.0"

# Build JSON APIs with ease [https://github.com/rails/jbuilder]
gem "jbuilder", "~> 2.7"

# Reduces boot times through caching; required in config/boot.rb
gem "bootsnap", ">= 1.4.4", require: false

group :development, :test do
  gem "pry-byebug", "3.12.0"
  gem "sidekiq", "~> 7" # Background job processor -- when update, ensure `process_context_to_sidekiq_args` is still compatible
  # Sidekiq 7 calls connection_pool's `pop` positionally; connection_pool 3 made it keyword-only,
  # which breaks Sidekiq 7's scheduled poller against a real Redis. Sidekiq 7 declares no upper
  # bound, so cap it here. (Drop when bumping to Sidekiq 8, which supports connection_pool 3.)
  gem "connection_pool", "< 3"
end

group :development do
  # Speed up commands on slow machines / big apps [https://github.com/rails/spring]
  # gem "spring"
  gem "rubocop", "~> 1.21"
end

group :test do
  # These are only needed for development of Axn itself
  gem "faraday", "~> 2.0" # For client strategy testing
  gem "rspec", "~> 3.2"
  gem "semantic_logger", "~> 4.0" # Confirms auto-log facet forwarding to a real SemanticLogger (PRO-2854)
end
